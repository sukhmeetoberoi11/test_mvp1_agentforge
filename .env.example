# Environment variables required by this agent
# Copy to .env and fill in values

# Number of pod replicas for medium load (recommend 3-5)
REPLICAS=
# Logging verbosity level for compliance audit trails
LOG_LEVEL=
# Hostname or IP of Qdrant vector store instance
QDRANT_HOST=
# Port number for Qdrant connection (default 6333)
QDRANT_PORT=
# Authentication key for Qdrant vector store
QDRANT_API_KEY=
# API key for Claude 3.5 Sonnet model access
ANTHROPIC_API_KEY=
# API endpoint for billing system integration
BILLING_SYSTEM_URL=
# API endpoint for knowledge base access
KNOWLEDGE_BASE_URL=
# Key for encrypting personally identifiable information
PII_ENCRYPTION_KEY=
# Maximum API requests per minute for rate limiting
RATE_LIMIT_REQUESTS=
# Connection string for account database
ACCOUNT_DATABASE_URL=
# API endpoint for ticket management system
TICKET_MANAGEMENT_URL=
